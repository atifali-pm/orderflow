APP_NAME=Orderflow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8050

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (Postgres in docker)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=orderflow
DB_USERNAME=orderflow
DB_PASSWORD=orderflow

# Postgres host-side port (for psql, TablePlus, etc.)
DB_HOST_PORT=5457

# Redis (cache, sessions, queue)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_HOST_PORT=6383

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Mail (Mailpit in docker)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@orderflow.local
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit web UI host port
MAILPIT_HOST_PORT=8025

# n8n integration
# In-cluster URL Laravel uses to call n8n. n8n listens on 5678 inside the docker network.
N8N_WEBHOOK_URL_BASE=http://n8n:5678/webhook
# Shared HMAC secret. Laravel signs outbound payloads; n8n nodes verify.
N8N_HMAC_SECRET=change-me-to-a-long-random-string
# Per-workflow bearer token n8n sends when calling Laravel API endpoints.
N8N_API_TOKEN=change-me-to-a-long-random-string
# n8n host-side port (web UI for editing workflows from your browser)
N8N_HOST_PORT=5679

# App host-side port (nginx)
APP_HOST_PORT=8050
