        "jsCode": "const ref = $('Extract fields').first().json.orderRef;\nconst invoiceNumber = 'INV-' + Date.now().toString().slice(-8) + '-' + Math.floor(Math.random() * 1000);\nreturn [{ json: { invoiceNumber, ref } }];"
      },
