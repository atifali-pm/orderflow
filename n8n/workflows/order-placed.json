    {
      "parameters": {
        "jsCode": "// Verify the HMAC-SHA256 signature against the canonical (deeply-sorted-keys) JSON body.\n// Must match the Laravel HmacSigner exactly so signatures verify deterministically.\nconst crypto = require('crypto');\n\nfunction sortKeysDeep(value) {\n  if (Array.isArray(value)) return value.map(sortKeysDeep);\n  if (value && typeof value === 'object') {\n    const out = {};\n    for (const k of Object.keys(value).sort()) out[k] = sortKeysDeep(value[k]);\n    return out;\n  }\n  return value;\n}\n\nconst input = $input.first().json;\nconst body = input.body || {};\nconst headers = input.headers || {};\nconst providedSig = headers['x-orderflow-signature'] || '';\nconst secret = $env.ORDERFLOW_HMAC_SECRET || '';\n\nconst canonical = JSON.stringify(sortKeysDeep(body));\nconst expected = crypto.createHmac('sha256', secret).update(canonical).digest('hex');\n\nlet valid = false;\ntry {\n  valid = providedSig.length === expected.length && crypto.timingSafeEqual(\n    Buffer.from(providedSig, 'utf8'),\n    Buffer.from(expected, 'utf8'),\n  );\n} catch (e) {\n  valid = false;\n}\n\nreturn [{ json: { ...input, _hmacValid: valid, _hmacExpected: expected } }];"
      },
      "id": "node-verify-hmac",
      "name": "Verify HMAC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 320]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "hmac-ok",
              "leftValue": "={{ $json._hmacValid }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-if-valid",
